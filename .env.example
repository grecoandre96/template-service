# Variabili d'ambiente richieste dal servizio
# Su Railway vanno impostate nella dashboard (Settings → Variables)

# Chiave API per autenticare le chiamate dall'esterno (es. n8n)
# Genera una stringa casuale sicura, es: openssl rand -hex 32
API_KEY=

# Porta del server — Railway la imposta automaticamente, non toccare
PORT=3000

# Percorso del volume persistente — deve corrispondere al mount path su Railway
DATA_DIR=/app/data

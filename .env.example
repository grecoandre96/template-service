# Copia questo file in .env per lo sviluppo locale

# Chiave API per autenticare le chiamate (scegli una stringa sicura)
API_KEY=cambia-questa-chiave-con-una-sicura

# Porta del server (Railway la imposta automaticamente)
PORT=3000

# Cartella dove vengono salvati i template e il DB
# Su Railway questa deve corrispondere al mount path del volume
DATA_DIR=./data
